Host github-nuoa
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_ed25519_nuoa
  IdentitiesOnly yes
  AddressFamily inet
  ControlMaster no
  ControlPath none

Host github.com
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  AddressFamily inet

Host fpt-serverless
  HostName tcp-endpoint.serverless.fptcloud.com
  User root
  Port 34541
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host *
  # Security hardening
  StrictHostKeyChecking accept-new
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  ServerAliveInterval 300
  ServerAliveCountMax 2
  ControlMaster auto
  ControlPath ~/.ssh/control-%C
  ControlPersist 600

  # Modern algorithms
  HostKeyAlgorithms ssh-ed25519,ecdsa-sha2-nistp256,ecdsa-sha2-nistp384
  PubkeyAcceptedKeyTypes ssh-ed25519,ecdsa-sha2-nistp256,ecdsa-sha2-nistp384
  KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org
  Ciphers chacha20-poly1305@openssh.com,aes128-gcm@openssh.com,aes256-gcm@openssh.com
  MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
